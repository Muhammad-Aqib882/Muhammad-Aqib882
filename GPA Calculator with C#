namespace Std;
class Subject
{
    public string Name { get; set; }
    public int CreditHours { get; set; }
    public double GradePoint { get; set; }

    public Subject(string name, int creditHours, double gradePoint)
    {
        Name = name;
        CreditHours = creditHours;
        GradePoint = gradePoint;
    }
}


class GpaCalculator
{
    private List<Subject> subjects = new List<Subject>();

    public void AddSubject(Subject subject)
    {
        subjects.Add(subject);
    }

    public double CalculateGPA()
    {
        double totalPoints = 0;
        int totalCredits = 0;

        foreach (var sub in subjects)
        {
            totalPoints += sub.GradePoint * sub.CreditHours;
            totalCredits += sub.CreditHours;
        }

        if (totalCredits == 0)
            return 0;

        return totalPoints / totalCredits;
    }
}


class Program
{
    static void Main()
    {
        GpaCalculator calculator = new GpaCalculator();

        calculator.AddSubject(new Subject("Math", 3, 4.0));
        calculator.AddSubject(new Subject("Physics", 3, 3.7));
        calculator.AddSubject(new Subject("Programming", 4, 3.5));

        double gpa = calculator.CalculateGPA();

        Console.WriteLine("Your GPA is: " + gpa);
    }
}
